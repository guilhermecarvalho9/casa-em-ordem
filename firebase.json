{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "hosting/public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/casa/**",
        "destination": "/casa/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
